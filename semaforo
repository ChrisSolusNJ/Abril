async function obtenerRegistros(){
    try {
        const response = await fetch('../produccion/php/semaforo.php?obtenerRegistrosTurno');
        const data = await response.json();
        if(data.success){
            currentTurno = data.turnoActual;
            const totalRegistros = data.total_registros_turno;

            actualizarSemaforoTaches(totalRegistros);
        }
    } catch (error) {
         console.error('Error al obtener estadísticas:', error);
    }
}

function actualizarSemaforoTaches(cantidad) {
    // Semáforo
    const amarillo = cantidad >= 1;
    const naranja = cantidad >= 2;
    const rojo = cantidad >= 3;
    
    if (amarillo) luzAmarilloBCM4.classList.add('active');
    else luzAmarilloBCM4.classList.remove('active');
    
    if (naranja) luzNaranjaBCM4.classList.add('active');
    else luzNaranjaBCM4.classList.remove('active');
    
    if (rojo) luzRojoBCM4.classList.add('active');
    else luzRojoBCM4.classList.remove('active');
    
    // Taches
    tachesContainerBCM4.innerHTML = '';
    
    if (cantidad === 0) {
        tachesContainerBCM4.innerHTML = '<div style="color:#5b6e8c;">Sin registros en este turno</div>';
        return;
    }
    
    const taches = [];
    for (let i = 0; i < Math.min(cantidad, 3); i++) {
        taches.push('✗');
    }
    if (cantidad > 3) {
        taches.push('+');
    }
    
    taches.forEach(simbolo => {
        const div = document.createElement('div');
        div.className = 'tache';
        if (simbolo === '+') div.classList.add('mas');
        div.innerText = simbolo;
        tachesContainerBCM4.appendChild(div);
    });
}

async function init(){
    await obtenerRegistros();
    setInterval(init, 60000); // Ejecutar cada minuto (60000 ms)
}

